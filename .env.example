# 运行环境: dev | prod
AISPIDER_ENV=dev

# Redis
AISPIDER_REDIS_URL=redis://localhost:6379/0

# PostgreSQL
AISPIDER_PG_DSN=postgresql://aispider:aispider@localhost:5432/aispider

# Kafka
AISPIDER_KAFKA_BROKERS=localhost:9092

# MinIO
AISPIDER_MINIO_ENDPOINT=localhost:9000
AISPIDER_MINIO_ACCESS_KEY=minioadmin
AISPIDER_MINIO_SECRET_KEY=minioadmin

# JWT (REQUIRED: must be set, no default value)
AISPIDER_JWT_SECRET=your-secret-key-here-min-32-chars
AISPIDER_JWT_EXPIRE_MINUTES=1440
AISPIDER_CORS_ORIGINS=http://localhost:3001

# Auth bootstrap (optional, used when spider_users is empty)
AISPIDER_BOOTSTRAP_ADMIN_USERNAME=
AISPIDER_BOOTSTRAP_ADMIN_PASSWORD=

# 日志
AISPIDER_LOG_DIR=/var/log/aispider
AISPIDER_LOG_LEVEL=INFO

# 调度器
AISPIDER_SCHEDULER_MAX_WORKERS=10
AISPIDER_SCHEDULER_COMMAND_STATUS_TTL_SECONDS=86400
AISPIDER_SCHEDULER_COMMAND_DEDUPE_TTL_SECONDS=86400

# 代理池 (熊猫代理)
AISPIDER_PANDAS_PROXY_ORDER_ID=
AISPIDER_PANDAS_PROXY_SECRET=
AISPIDER_PANDAS_PROXY_REDIS_KEY=pandas_proxy
AISPIDER_PANDAS_PROXY_POOL_SIZE=150

# 告警通知
AISPIDER_WECHAT_WEBHOOK_KEY=
AISPIDER_DINGTALK_WEBHOOK_URL=
AISPIDER_FEISHU_WEBHOOK_URL=

# PostgreSQL (docker-compose)
PG_PASSWORD=change-me-postgres-password

# MinIO (docker-compose)
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key

# Grafana
GRAFANA_PASSWORD=change-me-grafana-password
